# file: .env.example
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Auth
AUTH_SECRET="trocar_em_producao"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN="APP_USR_xxx_ou_TEST_xxx"
MERCADOPAGO_WEBHOOK_SECRET="(opcional_se_nao_usar_assinatura)"

# Cloudinary
CLOUDINARY_CLOUD_NAME="xxx"
CLOUDINARY_API_KEY="xxx"
CLOUDINARY_API_SECRET="xxx"

# Melhor Envio (se estiver usando)
MELHORENVIO_ENV="production"
MELHORENVIO_TOKEN="xxx"
MELHORENVIO_FROM_CEP="00000-000"

# Analytics (opcional)
NEXT_PUBLIC_META_PIXEL_ID=""
NEXT_PUBLIC_GA_ID=""

# Seed admin
SEED_ADMIN_EMAIL="admin@cuiaslazaretti.com.br"
SEED_ADMIN_PASSWORD="TROCAR-EM-PRODUCAO"
